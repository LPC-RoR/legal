<div class="row gx-1">
	<div class="col-8">
		<b><%= objeto.glosa %></b>
	</div>
	<div class="col-2 text-end">
		<%= s_pesos(objeto.monto) %>
	</div>
	<div class="col-2 text-end objt_lnk">
		<%= render partial: '0p/tbl/lnks_e', locals: {objeto: objeto} if current_usuario.dog? %>
	</div>
</div>
<% if objeto.tar_facturaciones.any? %>
	<div class="mx-5">
		<% objeto.tar_facturaciones.each do |fctrcn| %>
			<%= render partial: prtl(fctrcn, 'list', 'objt_fin'), locals: {objeto: fctrcn} %>
		<% end %>
	</div>
<% end %>