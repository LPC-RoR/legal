<%= render partial: '0p/lbld_inpts/text', locals: { form: form, token: :glosa, label: 'Glosa' } %>
<div class='row'>
	<div class='col-lg-6 col-xs-12'>
		<%= render partial: '0p/lbld_inpts/check_box', locals: { form: form, token: :recalcular, label: 'Recalcular' } %>
		<%= render partial: '0p/lbld_inpts/date_clndr', locals: { form: form, token: :fecha_uf, label: 'Fecha UF' } %>
	</div>
	<div class='col-lg-6'>
		<%= render partial: '0p/lbld_inpts/select', locals: { form: form, token: :tipo_monto, label: 'Tipo monto', sel_list: ['Total', 'Parcial'] } %>
		<%= render partial: '0p/lbld_inpts/number', locals: { form: form, token: :monto_parcial, label: 'Monto parcial' } %>
		<%= render partial: '0p/lbld_inpts/number', locals: { form: form, token: :porcentaje, label: 'Porcentaje' } %>
	</div>
</div>

<%= render partial: '0p/lbld_inpts/hidden', locals: {form: form, token: :ownr_type} %>
<%= render partial: '0p/lbld_inpts/hidden', locals: {form: form, token: :ownr_id} %>
<%= render partial: '0p/lbld_inpts/hidden', locals: { form: form, token: :tar_calculo_id } %>
<%= render partial: '0p/lbld_inpts/hidden', locals: { form: form, token: :codigo_formula } %>