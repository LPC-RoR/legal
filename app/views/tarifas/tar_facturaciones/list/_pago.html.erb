<% case objeto.ownr.class.name %>
<% when 'Causa' %>
	<%= objeto.glosa %>
	<%#= objeto.tar_pago.tar_pago %> 
<% when 'Asesoria' %>
	<%= "Asesoría #{objeto.ownr.tipo}" %>
<% end %>

<i class="bi bi-dot"></i>
<%= render partial: 'tarifas/tar_facturaciones/list/aprobacion_factura', locals: {objeto: objeto} %>

</br>

<div align="right">
	<b>
	<%= s_uf(objeto.monto_uf) %>
	<i class="bi bi-arrow-left-right"></i>
	<%= s_pesos(objeto.monto_pesos) %>
	</b>
</div>