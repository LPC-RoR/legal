<%= render partial: '0p/ttl_clss', locals: {source: 'clientes', clss: :gray, dir: 'shw'} %>
<%= render partial: 'layouts/partials/notice_alert' %>

<%= render partial: '0p/objt/cambio_estado', locals: { stts: ['ingreso', 'activo', 'baja'] } if dog? %>
<%#= render partial: 'st_estados/st_estados/partials/change_state', locals: {objeto: @objeto} %>

<%= render partial: '0p/tabs/tabs', locals: { token: :menu } %>
<div class="p-1 border-start border-end border-bottom" style="margin-top: -1px;">
	
	<% case @options[:menu] %>
	<% when 'General' %>
		<%# DEPRECATED PENDIENTE en despliegue de app_archivos %>
		<%= render partial: '0shr/rcss', locals: {objeto: @objeto} %>
	<% when 'Causas' %>
		<%= render partial: 'causas/indx/indx', locals: {estados: @estados, tipos: @tipos, tipo: @tipo, estado: @estado, path: @path} %>
	<% when 'Asesorias' %>
		<%= render partial: prtl_name('asesorias', 'indx', 'indx'), locals: {estados: @estados, tipos: @tipos, tipo: @tipo, estado: @estado, path: @path} %>
	<% when 'Facturas' %>
		<h4>Revisión de facturas</h4>
		<% @causas_revision.each do |causa| %>
			<div class="row gx-1">
				<div class="col-4"><%= causa.rit %></div>
				<div class="col-4"><%= causa.estado_financiero%></div>
				<div class="col-4"><%= causa.tar_facturaciones.count %> : <%= causa.doc_detalles.count %></div>
			</div>
		<% end %>
		<hr>
		<%= render partial: 'tarifas/tar_facturas/indx/indx', locals: {estados: @estados, tipos: @tipos, tipo: @tipo, estado: @estado, path: @path} %>
	<% when 'Tarifas' %>
		<%= render partial: 'clientes/shw/ndx_tarifas', locals: {objeto: @objeto, estado: @estado, tipo: @tipo, path: @path} %>
	<% end %>
	
</div>
