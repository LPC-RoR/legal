<% if current_usuario.admin? %>
	<%= link_to pdf_designacion_krn_denuncia_path(@objeto), data: {turbo_confirm: "¿Estás seguro?"} do %>
	    <i class="bi bi-plus-circle"></i>
	<% end %>
	<%= link_to pdf_notificaciones_krn_denuncia_path(@objeto), data: {turbo_confirm: "¿Estás seguro?"} do %>
	    <i class="bi bi-send"></i>
	<% end %>
	<%= link_to pdf_declaraciones_krn_denuncia_path(@objeto), data: {turbo_confirm: "¿Estás seguro?"} do %>
	    <i class="bi bi-person-lines-fill"></i>
	<% end %>
	<%= link_to pdf_pruebas_krn_denuncia_path(@objeto), data: {turbo_confirm: "¿Estás seguro?"} do %>
	    <i class="bi bi-folder2-open"></i>
	<% end %>
<% end %>