  <div class="mb-3">

    <%# Se selecciona la Clase que gestiona el código %>
    <% lst_clss = ClssTxt.txt_clss?(@objeto.codigo) %>
    <% name_clss = ClssTxt.txt_name_clss?(@objeto.codigo) %>

    <%= form.label :codigo, "Formato", class: "form-label" %>
    <%# texto_aninimizado, resumen_cronologico %>
    <% if ClssPdfRprt.txt_gnrds?(@objeto.codigo) %>
      <div class="mb-3">
        <%= form.label :codigo, "Código", class: "form-label" %>
        <%= form.text_field :codigo, 
                           class: "form-control",
                           placeholder: "Código",
                           readonly: ClssPdfRprt.txt_gnrds?(@objeto.codigo) %>
      </div>
    <% else %>
      <%= form.select :codigo, 
          options_for_select(
            @cdgs_list.map { |codigo| [name_clss.act_nombre[codigo], codigo] },
            @objeto.codigo
          ) 
      %>    
    <% end %>

  </div>

  <div class="mb-3">
    <%= form.label :titulo, "Título", class: "form-label" %>
    <%= form.text_field :titulo, 
                       class: "form-control",
                       placeholder: "Título del reporte" %>
  </div>

  <div class="mb-3">
    <%= form.label :contenido, "Texto", class: "form-label" %>
    
    <%# Trix editor nativo de Rails 8 %>
    <%= form.rich_text_area :contenido, 
                        class: "trix-content",
                        placeholder: "Escribe o pega el contenido aquí...",
                        data: { 
                          # Permite pegar desde Word/Google Docs
                          action: "trix-paste->editor#sanitize" 
                        } %>
    
    <small class="form-text text-muted">
      Puedes pegar contenido desde Word o Google Docs. 
      Usa los botones de la barra para listas, negritas, etc.
    </small>
  </div>

  <%= render partial: '0p/lbld_inpts/hidden', locals: { form: form, token: :ownr_type } %>
  <%= render partial: '0p/lbld_inpts/hidden', locals: { form: form, token: :ownr_id } %>