  <div class="mb-3">
    <%= f.label :codigo, "Código", class: "form-label" %>
    
    <% if params[:codigo].present? || f.object.codigo.present? %>
      <%# Código predefinido - solo lectura %>
      <%= f.text_field :codigo, 
                       class: "form-control", 
                       readonly: true,
                       style: "background-color: #e9ecec;" %>
      <small class="form-text text-muted">
        Código predefinido para esta sección
      </small>
    <% else %>
      <%# Código editable (cuando no viene por parámetro) %>
      <%= f.text_field :codigo, 
                       class: "form-control",
                       placeholder: "Ej: INTRODUCCION, ANTECEDENTES, etc." %>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :contenido, "Texto", class: "form-label" %>
    
    <%# Trix editor nativo de Rails 8 %>
    <%= f.rich_text_area :contenido, 
                        class: "trix-content",
                        placeholder: "Escribe o pega el contenido aquí...",
                        data: { 
                          # Permite pegar desde Word/Google Docs
                          action: "trix-paste->editor#sanitize" 
                        } %>
    
    <small class="form-text text-muted">
      Puedes pegar contenido desde Word o Google Docs. 
      Usa los botones de la barra para listas, negritas, etc.
    </small>
  </div>