<% act_id 			= "#{objeto.class.name}_#{objeto.id}" %>
<% email_validado 	= objeto.tiene_email_verificado? %>
<% email_verificado = objeto.tiene_email_validado? %>
<% articulo_516 	= objeto.articulo_516 %>

<div style="margin-left: 4%;">

	<%# Despliega email con email_mask & estado verificado|validado %>
	<%= render partial: 'karin/prtcpnts/objt/email_verification', locals: {objeto: objeto} %>

	<%# Despliegue de INFORMACIÓN Y NOTIFICACIONES %>

	<% if articulo_516 or email_verificado or email_validado %>
		<%= render layout: 'karin/krn_denuncias/shw/proceso/tsk_tmplt', locals: {ttl: 'Envío de información y notificaciones', gly: 'caret-right-fill'} do %>

			<%= render partial: prtl('act_archivos', nil, 'dsply_rprts'), locals: {hsh: @acts_hsh, mdl: ClssPrcdmnt, ownr: objeto, lnks: true} %>

		<% end %>
	<% end %>

	<% if @objeto.krn_inv_denuncias.any? %>
		<%= render partial: '0p/tbl_box', locals: {source: 'krn_declaraciones', dir: 'indx', ownr: objeto, clss_ttl: 'bg_azul_claro'} %>
	<% end %>

	<% unless (@acts_hsh[objeto.clss_id] and @acts_hsh[objeto.clss_id][:cdgs].empty?) %>
		<%= render layout: 'karin/krn_denuncias/shw/proceso/tsk_tmplt', locals: {ttl: 'Documentos controlados', gly: 'caret-right-fill'} do %>
			<%= render partial: 'repositorios/act_archivos/dsply_cntrlds', locals: {hsh: @acts_hsh, mdl: ClssPrcdmnt, ownr: objeto, dsply_lnks: true} %>
		<% end %>
	<% end %>

	<% if objeto.audit_notas.any? %>
		<%= render partial: prtl_name('audit_notas', nil, 'ownr_list'), locals: {objeto: objeto} %>
	<% end %>

</div>