<%# Este partial se unificó con el código de _dsply_act_archivo pero no cumplen el mismo propósito %>
<%# _dsply_act_archivo se usa para controlar los reportes administrativos. En ese contexto, el reporte es el título %>
<%# en este partial el reporte es una línea de una lista %>

<% es_lista 		= ClssPdfRprt.lista_rprt?(code) %>

<% act_archivos 	= es_lista ? ownr.act_archivos.exists?(act_archivo: code) : nil %>
<% act_referencias 	= es_lista ? ownr.act_referencias.exists?(code: code) : nil %>
<% chk_realizados 	= es_lista ? ownr.check_realizados.exists?(cdg: code) : nil %>

<% act_archivo 		= es_lista ? nil : ownr.act_archivos.find_by(act_archivo: code) %>
<% act_referencia	= es_lista ? nil : ownr.act_referencias.find_by(code: code) %>
<% chk_realizado 	= es_lista ? nil : ownr.check_realizados.find_by(cdg: code) %>

<% subido 			= act_archivos || act_referencias || act_archivo || act_referencia %>
<% realizado 		= chk_realizados || chk_realizado %>


<div class="row gx-1">
	<div class="col-lg-10 <%= 'text-primary' if (subido || realizado) %>">

		<% unless (subido || realizado) %>
			<% if @kproc.tarea == mdl.tsk_name[code] %>
				<i class="bi bi-arrow-right"></i>
			<% end %>
			<i class="bi bi-cone-striped text-danger"></i> 
		<% else %>
			<% if realizado %>
				<i class="bi bi-clipboard-check"></i>
			<% elsif es_lista %>
				<%# Se unificó el ícono para las listas %>
				<i class="bi bi-list-task text-secondary"></i>
			<% elsif act_archivo or act_referencia %>
				<i class="bi bi-file-earmark-pdf"></i>
			<% end %>
		<% end %>
		<%= ClssPrcdmnt.act_nombre[code] %>

	</div>

	<div class="col-lg-2 text-end app_lnk">

		<% unless (subido || realizado) && !ClssPdfRprt.mltpl_rprt(code) %>
			<%# Si hay más de uno como lo registro y se puede enviar uno y otro verificado!! %>

			<%= render layout: '0p/tltp_lnk', locals: {lnk: "/#{ownr.class.name.tableize}/#{ownr.id}/rlzd?mdl=act&cdg=#{code}&p=true", tltp: 'Realizado', data: {turbo_method: :post}} do %>
				<i class="bi bi-check-square"></i>
			<% end %>

			<%# REPORTES ADMINISTRATIVOS : ownr = dstntr y ref = Denuncia %>
			<%= render layout: '0p/tltp_lnk', locals: {lnk:"/krn_denuncias/#{@objeto.id}/krn_pdf_rprt?rprt=#{code}", tltp: 'Generar, almacenar y enviar reporte', data: {turbo_method: :post, turbo_confirm: 'Confirmar envío de email'}} do %>
				<i class="bi bi-envelope-at"></i>
			<% end %>
		<% else %>
			<% unless es_lista %>
				<% archivo = act_archivo ? act_archivo : (act_referencia ? act_referencia.act_archivo : nil) %>

				<% if subido && archivo %>
					<%# DOWNLOAD de ActArchivo %>
					<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/show_pdf", tltp: "Bajar #{ClssPrcdmnt.act_nombre[code].downcase}", target: '_blank'} do %>
						<i class="bi bi-download"></i>
					<% end %>

					<%# ELIMINAR ActArchivo %>
					<%= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: archivo} if current_usuario.dog? %>

				<% end %>
				<% if realizado && archivo %>
					<%= render layout: '0p/tltp_lnk', locals: {lnk: "/#{objeto.class.name.tableize}/#{objeto.id}/rlzd?mdl=act&cdg=#{code}&p=trash", tltp: 'Eliminar marca de realizado', data: {turbo_method: :post}} do %>
						<i class="bi bi-trash"></i>
					<% end %>
				<% end %>
			<% end %>
		<% end %>

	</div>

</div>

<% if act_archivos or act_referencias %>

	<% lista = act_archivos ? @objeto.act_archivos.where(act_archivo: code) : @objeto.act_referencias.where(code: code) %>
	<% lista.each do |rgstr| %>
		<% archivo = act_archivos ? rgstr : rgstr.act_archivo %>
		<% if archivo %>
		<div class="row gx-1 px-4 text-primary objt_lnk">
			<div class="col-10">
				<i class="bi bi-arrow-return-right"></i>
				<i class="bi bi-file-pdf"></i>
				<%= dma_hm(archivo.created_at)%>
			</div>
			<div class="col-2 text-end">
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/show_pdf", tltp: "Bajar #{ClssPrcdmnt.act_nombre[code].downcase}", target: '_blank'} do %>
					<i class="bi bi-download"></i>
				<% end %>
				<%# Sólo Dog puede eliminar un archivo enviado o generado %>
				<%= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: archivo} if current_usuario.dog? %>
				<i class="bi bi-arrow-return-left"></i>
			</div>
		</div>
		<% end %>
	<% end %>
<% end %>

<% if realizado %>

	<% lista = ownr.check_realizados.where(cdg: code) %>
	<% lista.each do |rgstr| %>
		<%= render partial: prtl(rgstr, nil, 'objeto'), locals: {objt: rgstr} %>
	<% end %>

<% end %>