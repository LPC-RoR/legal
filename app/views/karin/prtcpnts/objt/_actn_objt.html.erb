<%# Despliegue de una accion (generación y envíos de reportes) %>
<%# code : código del reporte %>
<%# mdl : ClssPrcdmnt %>

<% act_archivo 		= ownr.act_archivos.find_by(act_archivo: code) %>
<% act_referencia	= ownr.act_referencias.find_by(code: code) %>
<% revisado			= ownr.check_realizados.exists?(cdg: code) %>
<%# es_lista			= mdl.actn_multpl?(code) or mdl.ref_generated?(code) %>

<% es_lista 		= ClssPdfRprt.lista_rprt?(code) %>

<div class="row gx-1">

	<div class="col-lg-10 <%= 'text-primary' if act_archivo %>">

		<% if mdl.act_lst?(code) %>
			<%# Lista de act_archivos %>
			<i class="bi bi-list-task text-secondary"></i>

		<% elsif mdl.ref_generated?(code) %>
			<%# Act_files con Referencia %>
			<i class="bi bi-files text-secondary"></i>

		<% elsif act_archivo %>
			<%# Hay al menos un archivo asociado %>
			<i class="bi bi-file-earmark-pdf"></i>

		<% elsif revisado %>
			<i class="bi bi-clipboard-check"></i>
		<% else %>
			<%# tsk_name agrega prefijo 'tsk_' al nombre del reporte %>
			<% if @kproc.tarea == mdl.tsk_name[code] %>
				<i class="bi bi-arrow-right text-primary"></i>
			<% end %>
			<i class="bi bi-cone-striped text-danger"></i>
		<% end %>

		<%# secondary : Si se trata de una lista %>
		<span class="text-<%= es_lista ? 'secondary' : 'primary'%>">
			<%=mdl.act_nombre[code]%>
		</span>

	</div>

	<div class="col-lg-2 text-end app_lnk">

		<% if (not es_lista) and (act_archivo or act_referencia or revisado) %>

			<% if revisado %>
				<%# Eliminar Check de revisado %>
				<%= render partial: 'repositorios/check_realizados/rlzd', locals: {hsh: hsh, act_id: ownr.clss_id, ownr: ownr, act:code} %>
			<% else %>
				<%# Puede tener ActArchivo o ActReferencia %>

				<% if act_archivo %>
					<%# DOWNLOAD de ActArchivo %>
					<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_archivo.id}/show_pdf", tltp: "Bajar #{mdl.act_nombre[code].downcase}", target: '_blank'} do %>
						<i class="bi bi-download"></i>
					<% end %>
					<%# ELIMINAR ActArchivo %>
					<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_archivo.id}/rmv_cntrld", tltp: 'Remover archivo controlado', data: {turbo_method: :post, turbo_confirm: 'Confirmar eliminación del pdf'}} do %>
						<i class="bi bi-trash"></i>
					<% end %>
				<% else %>
					<%# DOWNLOAD de ActReferencia %>
					<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_referencia.act_archivo.id}/show_pdf", tltp: "Bajar #{act_referencia.act_archivo.nombre.downcase}", target: '_blank'} do %>
						<i class="bi bi-download"></i>
					<% end %>
				<% end %>


			<% end %>

		<% else %>
			<%# Marcar Check de revisado %>
			<% unless act_referencia %>
				<%= render partial: 'repositorios/check_realizados/rlzbl', locals: {hsh: hsh, act_id: ownr.clss_id, ownr: ownr, act: code} %>
			<% end %>

			<% unless mdl.ref_generated?(code) or ClssPdfRprt.ntfccn_rprt?(code) %>
				<%# Los reportes ref_generated se generan en el modelo REF %>
				<%# krn_pdf_rprt diferencia env{io directo de correos de  partcpnts con artículo 516 %>
				<%= render layout: '0p/tltp_lnk', locals: {lnk:"/krn_denuncias/#{ownr.dnnc.id}/krn_pdf_rprt?rprt=#{code}", tltp: 'Generar, almacenar y enviar reporte', data: {turbo_method: :post, turbo_confirm: 'Confirmar envío de email'}} do %>
					<i class="bi bi-envelope-at"></i>
				<% end %>

			<% end %>

		<% end %>
	</div>

</div>

<% if es_lista %>

	<% lista = ClssPdfRprt.ownr_rfrnc_rprt?(code) ? ownr.act_referencias.where(code: code) : ownr.act_archivos.where(act_archivo: code) %>

	<% lista.each do |objt| %>
		<% act_fl = objt.class.name == 'ActArchivo' ? objt : objt.act_archivo %>

		<div class="row gx-1 mx-3 text-primary">
			<div class="col-lg-10">
				<i class="bi bi-arrow-return-right"></i>
				<%= dma_hm(act_fl.created_at) %>
			</div>
			<div class="col-lg-2 text-end objt_lnk">
				<%# DOWNLOAD de ActArchivo %>
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_fl.id}/download", tltp: "Bajar #{mdl.act_nombre[code].downcase}", target: '_blank'} do %>
					<i class="bi bi-download"></i>
				<% end %>
				<%# ELIMINAR ActArchivo %>
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_fl.id}/rmv_cntrld", tltp: 'Remover archivo controlado', data: {turbo_method: :post}} do %>
					<i class="bi bi-trash"></i>
				<% end %>
				<i class="bi bi-arrow-return-left"></i>
			</div>
		</div>

	<% end %>

<% end %>