<% unless objt.tiene_email_verificado? or objt.articulo_516 %>
  <li>
    <%= render layout: '0p/tltp_lnk', locals: {lnk: url_params("/krn_testigos/#{objt.id}/reenviar_correo", {key: 'tstg'}), tltp: nil, data: { turbo_method: :post}, clss: 'dropdown-item'} do %>
      Enviar verificación de email
    <% end %>
  </li>

  <% unless objt.tiene_email_validado? %>
    <li>
      <%= render layout: '0p/tltp_lnk', locals: {lnk: url_params("/krn_testigos/#{objt.id}/rlzd", {mdl: 'act', cdg: 'verificar_email', p: true}), tltp: nil, data: { turbo_method: :post}, clss: 'dropdown-item'} do %>
        Marcar como validado
      <% end %>
    </li>
  <% else %>
    <li>
      <%= render layout: '0p/tltp_lnk', locals: {lnk: url_params("/krn_testigos/#{objt.id}/rlzd", {mdl: 'act', cdg: 'verificar_email', p: 'trash'}), tltp: nil, data: { turbo_method: :post}, clss: 'dropdown-item'} do %>
        Eliminar marca de validado
      <% end %>
    </li>
  <% end %>
<% end %>

<% if current_usuario.operacion? %>

  <%# En el caso de los testigos, cuida que se puedan ingresar hasta en la declaración del participante %>
  <%# modificable = @objeto.fecha_hora_dt.nil? and @objeto.fecha_trmtcn.nil? %>
  <%# REVISAR %>
  <% modificable = @objeto.fecha_trmtcn.nil? %>

  <% unless objt.tiene_email_verificado? or (not modificable) or objt.articulo_516 %>
    <li><hr class="dropdown-divider"></li>
  <% end %>

  <% if modificable %>
    <%= render partial: '0p/tbl/plldwn_editar', locals: {objt: objt, orgn: @orgn} %>
    <li><hr class="dropdown-divider"></li>
    <%= render partial: '0p/tbl/plldwn_eliminar', locals: {objt: objt, orgn: @orgn} %>
  <% end %>

  <%#= render partial: '0p/tbl/plldwn_show', locals: {objt: objt, orgn: @orgn} %>

<% end %>