<% validado 	= objeto.ownr.tiene_email_validado? %>
<% verificado 	= objeto.ownr.tiene_email_verificado? %>
<% articulo_516	= objeto.ownr.articulo_516 %>

<% if objeto.act_referencias.empty? and (not objeto.tiene_check_realizado?) %>

	<small>

	<% if validado || verificado || articulo_516 %>
	<%= render layout: '0p/tltp_lnk', locals: {lnk:"/krn_denuncias/#{@objeto.id}/krn_pdf_rprt?rprt=dclrcn&nid=#{objeto.id}", tltp: 'Generar, almacenar y enviar reporte', data: {turbo_method: :post, turbo_confirm: 'Confirmar envío de email'}} do %>
		<% if articulo_516 %>
			<i class="bi bi-archive"></i>
		<% else %>
			<i class="bi bi-envelope-at"></i>
		<% end %>
	<% end %>
	<% end %>

	<%= render partial: '0p/tbl/lnks_e', locals: {objeto: objeto} %></small>
<% else %>
	<i class="bi bi-check2-all"></i>
<% end %>