<!-- app/views/layouts/pdfs/base.html.erb -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= @reporte.to_s.humanize %> - <%= @empresa&.razon_social || 'Sistema' %></title>
  
  <!-- Bootstrap 5.3 CSS desde CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  
  <!-- Estilos adicionales para PDF (optimizaciones de impresión) -->
  <style>
    /* Ajustes para que Bootstrap funcione bien en PDFs */
    @page {
      size: letter;
      margin: 0.5in;
    }
    
    body {
      font-family: 'Open Sans', 'Helvetica Neue', Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.5;
      color: #333;
      background: #fff;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    
    /* Tablas Bootstrap en PDF */
    .table {
      font-size: 9.5pt;
    }
    
    .table th {
      background-color: #2c5282 !important;
      color: #fff !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    
    /* Cards en PDF */
    .card {
      border: 1px solid #dee2e6;
      page-break-inside: avoid;
    }
    
    /* Evitar que elementos se corten entre páginas */
    .no-break {
      page-break-inside: avoid;
    }
    
    .page-break {
      page-break-after: always;
    }
    
    /* Badges en PDF */
    .badge {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
  </style>
</head>
<body class="bg-white">
  <div class="container-fluid py-3">
    <%= yield %>
  </div>
</body>
</html>