<!-- app/views/layouts/pdfs/invstgcns/base.html.erb -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= @reporte.to_s.humanize %> - <%= @empresa&.respond_to?(:razon_social) ? @empresa.razon_social : 'Sistema' %></title>
  
  <!-- Bootstrap 5.3 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <style>
    @page { size: letter; margin: 0.5in; }
    
    body {
      font-size: 10pt;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    
    .pdf-header {
      border-bottom: 2px solid #2c5282;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
    }
    
    .pdf-title {
      color: #2c5282;
      font-weight: 700;
    }
    
    .contenido-rich-text {
      line-height: 1.6;
    }
    
    .contenido-rich-text p {
      margin-bottom: 0.75rem;
    }
  </style>
</head>
<body class="bg-white">
  <div class="container-fluid py-3">
    <%= yield %>
  </div>
</body>
</html>