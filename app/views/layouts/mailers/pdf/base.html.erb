<!-- app/views/layouts/mailers/pdf/base.html.erb -->
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    
    <!-- Bootstrap 5 CSS - SIN ESPACIOS EN LA URL -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Open Sans - SIN ESPACIOS EN LA URL -->
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
      /* Configuración para impresión/PDF */
      @media print {
        .table { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .badge { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .bg-light { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .bg-primary { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .bg-warning { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .bg-danger { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .text-white { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
        .alert-warning { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
      }
      
      body { 
        font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 11pt;
        line-height: 1.6;
        color: #6c757d;
      }
      
      .pdf-container {
        max-width: 210mm;
        margin: 0 auto;
        padding: 0 15mm 15mm 15mm; /* Reducido arriba: 10mm en vez de 15mm */
      }
      
      /* Estilos específicos del template dnncnt_info_oblgtr_pdf */
      .pdf-header {
        border-bottom: 1px solid #6c757d;
        padding-bottom: 20px;
        margin-bottom: 20px;
      }
      
      .pdf-logo {
        max-height: 60px;
      }
      
      .pdf-title {
        font-size: 18pt;
        font-weight: 700;
        color: #0d6efd;
        margin-top: 10px;
      }
      
      .document-meta {
        font-size: 9pt;
        color: #6c757d;
        margin-top: 5px;
      }
      
      .stamp {
        border: 2px solid #dc3545;
        color: #dc3545;
        padding: 10px 20px;
        text-align: center;
        font-weight: bold;
        text-transform: uppercase;
        margin: 20px 0;
        page-break-inside: avoid;
      }
      
      /* Ajustes de Bootstrap para PDF */
      .card { 
        border: 1px solid #dee2e6 !important; 
        break-inside: avoid; 
      }
      .table { font-size: 10pt; }
      .table-bordered { border: 1px solid #dee2e6 !important; }
      .table-bordered th, 
      .table-bordered td { border: 1px solid #dee2e6 !important; }
      
      /* Saltos de página */
      .page-break { page-break-after: always; }
      .page-break-before { page-break-before: always; }
      .avoid-break { page-break-inside: avoid; }
      
      .page-header { margin-bottom: 20px; }
      .page-footer { margin-top: 30px; font-size: 9pt; color: #6c757d; }
    </style>
  </head>
  <body>
    <div class="pdf-container">
      <%= yield %>
    </div>
  </body>
</html>