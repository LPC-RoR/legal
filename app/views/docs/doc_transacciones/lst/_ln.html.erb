<div class="row gx-1" style="font-size: 0.7rem;line-height: 1.5;">
	<div class="col-4">
		<%= dma (objt.fecha) %> <%= objt.descripcion %>
	</div>
	<div class="col-2">
		<% if objt.relacionable %>
			<% if objt.clasificacion.present? %>
				<% if objt.clasificacion == objt.relacionable_type %>
					<i class="bi bi-check-circle"></i>
				<% else %>
					<i class="bi bi-check2-square"></i>
				<% end %>
				<%= objt.clasificacion %>
			<% else %>
				<i class="bi bi-check-circle"></i>
				<%= objt.relacionable.class.name unless ['clientes', 'proveedores'].include?(controller_name)%>
			<% end %>
		<% else %>
			<% if objt.clasificacion.present? %>
				<i class="bi bi-check2-square"></i>
				<%= objt.clasificacion %>
			<% else %>
				Pendiente
			<% end %>
		<% end %>
	</div>
	<div class="col-4 text-end">
		<%= s_pesos(objt.monto) %> <%= objt.tipo_movimiento %>
	</div>
	<div class="col-2 text-end objt_lnk">
		<%= render layout: '0p/tltp_lnk', locals: {lnk: "/doc_pagos/new#{blngs_prms(objt)}", tltp: 'Conciliar'} do %>
			<i class="bi bi-plus-circle"></i>
		<% end %>
		<%= render layout: '0p/tltp_lnk', locals: {lnk: "/doc_notas/new#{ownr_prms(objt)}", tltp: 'Agregar nota'} do %>
			<i class="bi bi-window-plus"></i>
		<% end %>
		<%= render partial: '0p/tbl/lnks_e', locals: {objeto: objt} %>
	</div>
</div>

<div class="mx-2" style="font-size: 0.6rem;line-height: 1.5;">
	<% objt.doc_pagos.each do |pg| %>
		<div>
			<i class="bi bi-arrow-return-right"></i> 
			<%= objt.relacionable.razon_social %> <i class="bi bi-arrow-right"></i> 
			[Factura <%= pg.folio_referencia %>]: <%= s_pesos(pg.monto)%>
		</div>
	<% end %>

	<% objt.doc_notas.each do |nt| %>
		<div class="objt_lnk">
			<i class="bi bi-arrow-return-right"></i> 
			<%= nt.nota %> <%= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: nt} %>
		</div>
	<% end %>

</div>
