<% ln_clr = objt.tipo_detalle == 'Causa' ? 'Primary' : 'dark' %>
<tr class="text-<%=ln_clr%>">

	<td class="ps-2">
	  <% if objt.ownr %>
	    <i class="bi bi-arrow-return-right"></i>
	  <% else %>
	    <i class="bi bi-question-circle"></i>
	  <% end %>
	</td>
	<td><%= objt.tipo_detalle %></td>
	<td class="pe-3 text-end"><%= l(objt.fecha_uf) if objt.fecha_uf? %></td>
	<td><%= objt.glosa %></td>
	<td class="pe-3 text-end"><%= s_pesos(objt.monto) %></td>
	<td class="pe-2 text-end objt_lnk">
	  <%= render partial: '0p/tbl/lnks_e', locals: {objeto: objt} %>
	</td>

</tr>