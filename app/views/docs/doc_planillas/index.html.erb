<h1>Planillas SII</h1>
<span class="objt_lnk"><%= link_to "Cargar Planilla", new_doc_planilla_path %></span>

<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Período</th>
      <th>Estado</th>
      <th>Documentos</th>
      <th>Procesado</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @planillas.each do |p| %>
      <tr>
        <td class="objt_lnk">
          <%= link_to p.nombre_original, doc_planilla_path(p) %>
        </td>
        <td><%= p.periodo %></td>
        <td><%= p.estado %></td>
        <td><%= p.documentos_cargados %> / <%= p.total_documentos %></td>
        <td><%= l(p.procesado, format: :short) if p.procesado %></td>
        <td class="objt_lnk">
          <% if p.pendiente? %>
            <%= button_to "Procesar", procesar_doc_planilla_path(p), method: :post %>
          <% end %>
          <%= render partial: '0p/tbl/lnks_e', locals: {objeto: p} %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>