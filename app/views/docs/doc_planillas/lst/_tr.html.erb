<tr>
	<td class="ps-2 objt_lnk">
	  <%= link_to objt.nombre_original, doc_planilla_path(objt) %>
	</td>
	<td><%= objt.tipo %></td>
	<td><%= objt.periodo %></td>
	<td><%= objt.estado %></td>
	<td><%= objt.documentos_cargados %> / <%= objt.total_documentos %></td>
	<td><%= l(objt.procesado, format: :short) if objt.procesado %></td>
	<td class="pe-2 objt_lnk text-end">
	  <% if objt.pendiente? %>
	    <%#= button_to "Procesar", procesar_doc_planilla_path(objt), method: :post %>
	  <% end %>
	  <%= render partial: '0p/tbl/lnks_e', locals: {objeto: objt} %>
	</td>
</tr>