<div class="row gx-1 px-2 text-primary" style="font-size: 14px;">
	<div class="col">
		<% if objeto.tar_calculo.blank? %>
			Pendiente
		<% elsif objeto.tar_calculo.tar_aprobacion.blank? %>
			Pago generado
		<% elsif objeto.tar_facturacion.tar_factura.blank? %>
			Pago por facturar
		<% else %>
			Facturado
		<% end %>
		<% unless objeto.tar_calculo.blank? %>
			<%= s_pesos(objeto.tar_calculo.monto) %>
		<% end %>
	</div>
	<div class="col text-end app_lnk">
		<% if objeto.tar_facturaciones.none? %>
			<% if objeto.facturable? %>
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/tar_facturaciones/new?code=assr&bid=#{calculo.id}", tltp: 'Nuevo pago'} do %>
					<i class="bi bi-plus-circle"></i> Generar pago
				<% end %>

				<%#= render layout: '0p/tltp_lnk', locals: {lnk: "/tar_calculos/crea_pago_asesoria?oclss=#{objeto.class.name}&oid=#{objeto.id}", tltp: 'Genera pago', data: {turbo_method: :post}} do %>
					<!--Generar pago-->
				<%# end %>
			<% else %>
				UF no encontrada
			<% end %>
		<% else %>
			<% objeto.tar_facturaciones.order(:created_at).each do |fctn| %>
				<div class="row px-2 gx-1">
					<div class="col">
						<i class="bi bi-dot"></i><%= fctn.glosa %>
						<% unless fctn.cli_aprobacion_id.blank? %> 
							[aprob: <%=fctn.tar_aprobacion_id%>]
						<% end %>
					</div>
					<div class="col text-end">
						<%= s_pesos(fctn.monto) %>
					</div>
				</div>
			<% end %>
		<% end %>
	</div>
</div>