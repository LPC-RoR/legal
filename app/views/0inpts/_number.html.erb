<% objeto ||= @objeto %>
<div class="form-floating mb-3">

    <%= f.number_field tkn, value: objeto.send(tkn.to_s), step: :any, class: "form-control #{'is-invalid' if @objeto.errors[:name].any?}", id: label.parameterize, placeholder: label %>
    <%= f.label tkn, label, for: label.parameterize unless objeto.errors[tkn].any? %>
    <% if @objeto.errors[tkn].any? %>
      <div class="invalid-feedback">
        <%= @objeto.errors[tkn].join(', ') %>
      </div>
    <% end %>

</div>
