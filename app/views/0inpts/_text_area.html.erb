<% objeto ||= @objeto %>
<div class="form-floating mb-3">

    <%= f.text_area tkn, value: (objeto.blank? ? nil : objeto.send(tkn.to_s)), class: "form-control #{'is-invalid' if objeto.errors[:name].any?}", id: label.parameterize, placeholder: label %>
    <%= f.label tkn, label, for: label.parameterize unless @objeto.errors[tkn].any? %>
    <% if @objeto.errors[tkn].any? %>
      <div class="invalid-feedback">
        <%= objeto.errors[tkn].join(', ') %>
      </div>
    <% end %>

</div>