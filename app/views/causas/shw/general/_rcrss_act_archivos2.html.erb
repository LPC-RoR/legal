<div class="border rounded-2 m-1 p-1">
    <%# Pusimos el if porque se caía en producción en causas en las que no estaba definido (Apelaciones o algo así) %>
    <% if ClssTipos.archivos[@objeto.code_causa.to_sym] %>
        <% ClssTipos.archivos[@objeto.code_causa.to_sym].each do |arch| %>
            <% archivo = @objeto.act_archivos.find_by(act_archivo: arch[0]) %>
            <div class="row gx-1 px-2 app_lnk">
                <div class="col-8">
                    <i class="bi bi-file-earmark-pdf"></i>
                    <%= arch[1] %>
                </div>
                <div class="col-4 text-end">
                    <% if archivo %>
                        <%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/show_pdf", tltp: 'Ver PDF', target: '_blank'} do %>
                            <i class="bi bi-download"></i>
                        <% end %>
                        <i class="bi bi-dot"></i>
                        <%= render partial: '0p/tbl/link_eliminar', locals: {objeto: archivo} %>
                    <% else %>
                        <%= render partial: '0p/tbl/lnk_new', locals: {source: 'act_archivos', ownr: @objeto, prms: [['act', arch[0]], ['mdl', 'ClssTipos']]} %>
                    <% end %>
                </div>
            </div>
            <% if archivo %>
                <% archivo.act_metadatas.each do |mtdt| %>
                    <div class="mx-3">
                        <i class="bi bi-file-earmark-ruled"></i> <%=ClssActs.mtdt_nombre[mtdt.act_metadata]%>
                    </div>
                <% end %>
            <% end %>
        <% end %>
    <% end %>
</div>