<% calculo 		= ownr.tar_calculos.find_by(codigo_formula: pago.codigo_formula) %>
<% facturacion 	= ownr.tar_facturaciones.find_by(codigo_formula: pago.codigo_formula) %>
<% rgstr 		= calculo.nil? ? facturacion : calculo %>

<% dtlls 		= ownr.doc_detalles.where(codigo_formula: pago.codigo_formula) %>

<!-- Version 2.0 -->

<hr>

<% if calculo %>
	<div class="px-2">
	</div>
	<div class="row px-2 gx-1">
		<div class="col">
			<b>Cálculo tarifa</b>
			<!-- BOTÓN ELIMINA CALCULO -->
			<% if calculo.tar_aprobacion_id.blank? %>
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/tar_calculos/#{calculo.id}/elimina_calculo", tltp: 'Eliminar cálculo', data: {turbo_method: :post}} do %>
					<i class="bi bi-trash"></i>
				<% end %>
			<% end %>
		</div>
		<div class="col text-end fw-bold">
			<%= s_moneda( calculo.moneda, calculo.monto ) %>
		</div>
	</div>
	<div class="row px-2 gx-1">
		<div class="col">
			<i class="bi bi-dot"></i>Fecha cálculo
		</div>
		<div class="col text-end">
			<%= dma( calculo.created_at ) %>
		</div>
	</div>
	<div class="row px-2 gx-1">
		<div class="col">
			<i class="bi bi-dot"></i>Cuantía utilizada para el cálculo
		</div>
		<div class="col text-end">
			<%= s_pesos( calculo.cuantia_calculo ) %>
		</div>
	</div>

	<%# PAGOS %>
	<div class="row gx-1 mt-2 px-2">
		<div class="col">
			<b>Pago(s)</b>
		</div>
		<div class="col text-end">
			<%= render layout: '0p/tltp_lnk', locals: {lnk: "/tar_facturaciones/new?code=clcl&bid=#{calculo.id}", tltp: 'Nuevo pago'} do %>
				<i class="bi bi-plus-circle"></i>
			<% end %>
		</div>
	</div>

	<% unless calculo.tar_facturaciones.empty? %>
		<% calculo.tar_facturaciones.order(:created_at).each do |fctn| %>
			<div class="row px-2 gx-1">
				<div class="col">
					<i class="bi bi-dot"></i><%= fctn.glosa %>
					<% unless fctn.cli_aprobacion_id.blank? %> 
						[aprob: <%=fctn.tar_aprobacion_id%>]
					<% end %>
				</div>
				<div class="col text-end">
					<%= s_pesos(fctn.monto) %>
				</div>
			</div>
		<% end %>
	<% end %>

<% end %>

<% if dtlls.any? %>
	<hr>
	<b>Facturación</b><br>
	<% dtlls.each do |dtll| %>
		<%= render partial: prtl(dtll, 'lst', 'objt_fin'), locals: {objeto: dtll} %>
	<% end %>
<% end %>

<% unless calculo || dtlls.any? %>
	<% if ownr.class.name == 'Causa' and controller_name == 'causas' %>
		</br>
		<%= render layout: '0p/bttn', locals: {lnk: "/tar_calculos/crea_calculo#{ownr_prms(ownr)}&pid=#{pago.id}", mthd: :post} do %>
			<i class="bi bi-cursor"></i> Autorizar pago
		<% end %>
    <% end %>
<% end %>

