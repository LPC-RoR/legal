<!-- Versión 2.0 -->
<!-- Aprobación de pagos -->

<%# TITULO con asignación de Tarifas a la Causa %>
<%= render partial: '0p/ttl_clss', locals: {source: 'tar_pagos', clss: :sub, dir: 'pgs', blngs: objeto} %>

<%# CLLPS de Asignación de Tarifas %>
<%= render layout: '0p/collapse/display', locals: {label: 'CambioTarifa', objeto: nil} do %>
	<%= render partial: prtl_name('tar_tarifas', 'indx/cllps', "cambio_tarifa"), locals: {blngs: objeto} %>
<% end %>

<% if objeto.tar_tarifa.blank? %>
	<div class="m-2"><i class="bi bi-cone-striped"></i> La causa no tiene tarifa asignada.</div>
<% elsif objeto.tar_tarifa_tar_pagos.empty? %>
	<div class="m-2"><i class="bi bi-cone-striped"></i> La tarifa asignada a la causa no tiene pagos definidos.</div>
<% else %>
	<% objeto.tar_tarifa_tar_pagos.ordr.each do |pago| %>
			<div class="mt-1 p-2 border border rounded-2 app_lnk" style="font-size: 13px;line-height: 1.2;">

				<%# ENCABEZADO DE CADA PAGO %>
				<%# Rev: 20-05-2026 %>
				<%= render partial: 'causas/shw/tarifa_pagos/aprobacion/encabezado', locals: {pago: pago, ownr: objeto} %>

				<% valor_uf = objeto.calc_valor_uf(pago.codigo_formula) %>
				<% fecha_uf = objeto.calc_fecha_uf(pago.codigo_formula) %>

				<% unless !!pago.requiere_uf == true and valor_uf.nil? %>
					<%# Rev: 20-05-2026 %>
					<%= render partial: 'causas/shw/tarifa_pagos/aprobacion/comentarios_pago', locals: {pago: pago, causa: objeto } %>
					<%# Rev: 20-05-2026 %>
					<%= render partial: 'causas/shw/tarifa_pagos/aprobacion/calculo_child', locals: {pago: pago, ownr: objeto } %>
				<% end %>

			</div>

	<% end %>
<% end %>