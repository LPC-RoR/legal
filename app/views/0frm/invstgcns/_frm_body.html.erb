<div class="pt-3 px-1">
	<%= form_with(model: @objeto, local: true, data: data) do |f| %>
		<% if @objeto.errors.any? %>
		<div id="error_explanation">
			<h4 class='text-warning'><%= @objeto.errors.count %> <%= @objeto.errors.count == 1 ? 'error' : 'errores' %> evitan que este registro sea grabado:</h4>

			<ul>
			<% @objeto.errors.full_messages.each do |message| %>
			<li class='text-warning'><%= message %></li>
			<% end %>
			</ul>
  
		</div>
		<% end %>

		<%# frm se crea para cambiar form por f %>
		<% form_prtl = prtl?(@objeto, nil, 'frm') ? prtl(@objeto, nil, 'frm') : fields_prtl(@objeto) %>

		<% if form_prtl %>
			<% if prtl?(@objeto, nil, 'frm') %>
				<%= render partial: form_prtl, locals: {c: controller_name, f: f} %>
			<% else %>
				<%= render partial: form_prtl, locals: {c: controller_name, form: f} %>
			<% end %>

			<%# La ruta de redirección se pasa como campo oculto al controlador para garantizar la redirección %>
			<%= hidden_field_tag :bck_rdrccn, @bck_rdrccn %>
		<% else %>
			<h3>Ne se encontró archivo con el formulario</h3>
		<% end %>

		<div class="my-3">
			<div class="row">
				<div class="col app_lnk">
					<%= f.submit "#{ action_name == 'new' ? (@objeto.class.name == 'RepArchivo' ? 'Subir' : 'Crear') : 'Modificar'} #{to_name(@objeto.class.name).downcase}" %>
				</div>
				<div class="col text-end pt-3">
					<% if prtl?(@objeto, 'hlp', 'detail') %>
						<%= render layout: '0p/mdl/link', locals: {cdg: 'hlp_detail', tltp: 'Ayuda'} do %>
							<i class="bi bi-cursor"></i> ¿Necesita ayuda para llenar este formulario?
						<% end %>
						<%= render partial: '0p/mdl/mdl', locals: {cdg: "hlp_detail", ttl: "Ingreso de #{to_name(@objeto).downcase}", prtl: prtl_name(@objeto, 'hlp', 'detail'), sz: 'lg'} %>
					<% end %>
				</div>
			</div>
		</div>
	<% end %>
</div>