<%= render partial: 'aplicacion/home/public/ticker' %>
<div class="m-3">

	<!-- Navbar superpuesta -->
	<nav class="navbar navbar-expand-md navbar-light overlay-nav">
	    <div class="container-fluid px-3">
	      <!-- Branding (opcional, a la izquierda) -->
	      <%#= link_to 'LaborSafe', root_path, class: 'navbar-brand d-none d-md-inline' %>
	      <%= render layout: '0p/tltp_lnk', locals: {lnk: root_path, tltp: nil} do %>
	      	<%= image_tag 'logo/logo_130.png', class: 'img-fluid' %>
	      <% end %>

	      <!-- Botón hamburguesa -->
	      <button class="navbar-toggler ms-auto" type="button"
