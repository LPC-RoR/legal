	              aria-controls="heroNav" aria-expanded="false" aria-label="Toggle navigation">
	        <span class="navbar-toggler-icon"></span>
	      </button>

	      <!-- Ítems de menú -->
	      <div class="collapse navbar-collapse" id="heroNav">
	        <ul class="navbar-nav ms-auto align-items-md-center">
	          <li class="nav-item">
	              <%= link_to 'Iniciar sesión', new_usuario_session_path, class: 'me-5 nav-link fs-6' %>
	          </li>
	        </ul>
	      </div>
	    </div>
	</nav>

	<div class="ubuntu_titulo" style="font-size: 2.5rem;line-height: 1.2;margin-left: 10rem;">
		Software para la gestión integral de<br>
		procedimientos de investigación y sanción<br>
		Ley 21.643 (Ley Karin)
	</div>
</div>


