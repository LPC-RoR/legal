<% if !es_lista && act_archivo %>
	<% if act_archivo %>
		<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_archivo.id}/download", tltp: "Bajar #{mdl.act_nombre[code].downcase}", target: '_blank'} do %>
			<i class="bi bi-download"></i>
		<% end %>

		<%= render partial: '0p/tbl/lnk_eliminar', locals: {objeto: act_archivo} %>
	<% end %>
<% end %>