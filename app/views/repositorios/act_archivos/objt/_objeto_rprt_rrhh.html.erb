<% act_archivos 	= objeto.act_archivos.where(act_archivo: rprt) %>
<% act_referencias 	= objeto.act_referencias.where(code: rprt) %>
<% realizado 		= objeto.check_realizados.where(cdg: rprt) %>

<div class="row gx-1 mx-1 mb-1 py-1 px-2 border rounded-2" style="font-size: .9rem;">
	<div class="col-8">
		<% unless act_archivos&.any? or act_referencias&.any? or realizado&.any? %>
			<i class="bi bi-cone-striped text-danger"></i> 
		<% end %>
		<%= ClssPrcdmnt.act_nombre[rprt] %>
	</div>
	<div class="col-4 text-end app_lnk">
		<%# Hay reportes que se pueden generar y enviar más de una vez, como infrmcn, hay que considerar esa posibilidad %>
		<% unless (act_archivos&.any? or act_referencias&.any? or realizado&.any?) and !ClssPdfRprt.mltpl_rprt(rprt) %>
			<%# Si hay más de uno como lo registro y se puede enviar uno y otro verificado!! %>

			<%= render partial: prtl('act_archivos', 'objt', 'btn_rlzd'), locals: {ownr: objeto, code: rprt} %>

			<%# REPORTES ADMINISTRATIVOS : ownr = dstntr y ref = Denuncia %>
			<%= render partial: prtl('act_archivos', 'objt', 'btn_email_rprt'), locals: {objeto: objeto, code: rprt, nid: objeto.id} %>

			<%# REPORTES ADMINISTRATIVOS : ownr = dstntr y ref = Denuncia %>
			<%#= render layout: '0p/tltp_lnk', locals: {lnk:"/krn_denuncias/#{@objeto.id}/krn_pdf_rprt?rprt=#{rprt}&nid=#{objeto.id}", tltp: 'Generar, almacenar y enviar reporte', data: {turbo_method: :post, turbo_confirm: 'Confirmar envío de email'}} do %>
				<!--i class="bi bi-envelope-at"></i-->
			<%# end %>

		<% end %>
	</div>

<% if act_archivos&.any? or act_referencias&.any? %>

	<% lista = act_archivos&.any? ? act_archivos : act_referencias %>
	<% lista.each do |rgstr| %>
		<% archivo = act_archivos&.any? ? rgstr : rgstr.act_archivo %>
		<% if archivo %>
		<div class="row gx-1 px-4 text-primary objt_lnk">
			<div class="col-10">
				<i class="bi bi-arrow-return-right"></i>
				<i class="bi bi-file-pdf"></i>
				<%= dma_hm(archivo.created_at)%>
			</div>
			<div class="col-2 text-end">

				<%= render partial: prtl('act_archivos', 'objt', 'btn_dwnld'), locals: {act_archivo: archivo, mdl: ClssPrcdmnt, code: rprt} %>
				<%#= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/show_pdf", tltp: "Bajar #{ClssPrcdmnt.act_nombre[rprt].downcase}", target: '_blank'} do %>
					<!--i class="bi bi-download"></i-->
				<%# end %>

				<%# Sólo Dog puede eliminar un archivo enviado o generado %>
				<%= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: archivo} if current_usuario.dog? %>
				<i class="bi bi-arrow-return-left"></i>
			</div>
		</div>
		<% end %>
	<% end %>
<% end %>

<% if realizado %>

	<%= render partial: prtl('check_realizados', nil, 'lst_rlzds'), locals: {ownr: @objeto, code: rprt} %>

<% end %>

</div>
