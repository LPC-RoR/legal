<%# Este partial se unificó con el código de _dsply_act_archivo pero no cumplen el mismo propósito %>
<%# _dsply_act_archivo se usa para controlar los reportes administrativos. En ese contexto, el reporte es el título %>
<%# en este partial el reporte es una línea de una lista %>

<%# VERSION 2.0 : Todo se maneja con listas act_archivos, act_referencias y chk_realizados %>

<%# DEBUG: Identificar qué clase de ownr está causando el error %>
<%# DEBUG: Capturar el error exacto con backtrace %>

<%# Resto del código original del partial... %>
<%# Usa Modelo de REPORTES %>
<% es_lista 		= ClssPdfRprt.lista_rprt?(code) %>

<%# Se cambia el código operativo antes de sacar es_lista para llevar a nil %>
<%# act_archivos 	ownr.act_archivos.where(act_archivo: code) %>
<%# act_referencias 	ownr.act_referencias.where(code: code) %>
<%# chk_realizados 	ownr.check_realizados.where(cdg: code) %>

<%# Líneas 53-55 con protección %>
<% act_archivos    = ownr.respond_to?(:act_archivos) ? ownr.act_archivos.where(act_archivo: code) : ActArchivo.none %>
<% act_referencias = ownr.respond_to?(:act_referencias) ? ownr.act_referencias.where(code: code) : ActReferencia.none %>
<% chk_realizados  = ownr.respond_to?(:check_realizados) ? ownr.check_realizados.where(cdg: code) : CheckRealizado.none %>

<% act_archivo 		= es_lista ? nil : ownr.act_archivos.find_by(act_archivo: code) %>
<% act_referencia	= es_lista ? nil : ownr.act_referencias.find_by(code: code) %>
<% chk_realizado 	= es_lista ? nil : ownr.check_realizados.find_by(cdg: code) %>

<% subido 			= act_archivos&.any? || act_referencias&.any? || act_archivo || act_referencia %>
<% realizado 		= chk_realizados&.any? || chk_realizado %>

<div class="row gx-1">
	<div class="col-lg-10 <%= 'text-primary' if (subido || realizado) %>">

		<% unless (subido || realizado) %>
			<% if @kproc.tarea == mdl.tsk_name[code] %>
				<i class="bi bi-arrow-right"></i>
			<% end %>
			<i class="bi bi-cone-striped text-<%= mdl.act_optnl?(code) ? 'primary' : 'danger' %>"></i> 
		<% end %>

		<% if es_lista %>
			<i class="bi bi-list-task text-secondary"></i>
		<% else %>
			<i class="bi bi-file-earmark-pdf"></i>
		<% end %>

		<%= ClssPrcdmnt.act_nombre[code] %>

	</div>

	<div class="col-lg-2 text-end app_lnk">

		<%# REVISAR uso de mltpl_rprt %>
		<% unless (subido || realizado) && !ClssPdfRprt.mltpl_rprt(code) %>
			<%# Si hay más de uno como lo registro y se puede enviar uno y otro verificado!! %>

			<!-- BTN REALIZADO NEW -->
			<%= render partial: '0p/tbl/lnk_new', locals: {source: 'check_realizados', ownr: ownr, gly: 'check2-square', gly_clss: 'text-success', prms: {cdg: code}} %>

			<!-- BTN REALIZADO -->
			<%#= render partial: prtl('act_archivos', 'objt', 'btn_rlzd'), locals: {ownr: ownr, code: code} %>

			<%# REPORTES ADMINISTRATIVOS : ownr = dstntr y ref = Denuncia %>
			<% unless code.start_with?('txt_') %>
				<%= render partial: prtl('act_archivos', 'objt', 'btn_email_rprt'), locals: {objeto: ownr, code: code} %>
			<% end %>

		<% else %>
			<% unless es_lista %>
				<% archivo = act_archivo ? act_archivo : (act_referencia ? act_referencia.act_archivo : nil) %>

				<% if subido && archivo %>
					<%# DOWNLOAD de ActArchivo %>
					<%#= render partial: prtl('act_archivos', 'objt', 'btn_dwnld'), locals: {act_archivo: archivo, mdl: ClssPrcdmnt, code: code} %>

					<%# ELIMINAR ActArchivo %>
					<%#= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: archivo} if current_usuario.dog? %>

				<% end %>
			<% end %>
		<% end %>

	</div>

</div>

<% if subido %>

	<% lista = act_archivos&.any? ? act_archivos : act_referencias %>
	
	<% lista.each do |rgstr| %>

		<% archivo = act_archivos&.any? ? rgstr : rgstr.act_archivo %>

		<% if archivo %>
		<div class="row gx-1 px-4 text-primary objt_lnk">
			<div class="col-10">
				<i class="bi bi-arrow-return-right"></i>
				<i class="bi bi-file-pdf"></i>
				<% if archivo.sndd %>
					<i class="bi bi-send-check"></i>
				<% end %>
				<%= dma_hm(archivo.created_at)%>
				<% if es_lista %>
					<%= archivo.nombre %>
				<% end %>
			</div>
			<div class="col-2 text-end">

				<%# El boton EXCLUIR aparece sólo en los códigos excluibles y siempre que tengan un pdf adjunto %>
				<% if ClssPdfRprt.exclbl_pdf?(code) and archivo.pdf.attached? %>
					<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/excluir", tltp: "#{!!archivo.excluir ? 'Incluir' : 'Excluir'} pdf", data: {turbo_method: :post}} do %>
						<i class="bi bi-file-earmark-<%= !!archivo.excluir ? 'plus' : 'minus'%>"></i>
					<% end %>
				<% end %>

				<%= render partial: prtl('act_archivos', 'objt', 'btn_dwnld'), locals: {act_archivo: archivo, mdl: ClssPrcdmnt, code: code} %>
				<%# Sólo DOG puede eliminar un archivo enviado o generado %>
				<%= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: archivo} if current_usuario.dog? %>
				<i class="bi bi-arrow-return-left"></i>
			</div>
		</div>
		<% end %>

	<% end %>
<% end %>

<% if realizado %>
	<%= render partial: prtl('check_realizados', nil, 'lst_rlzds'), locals: {ownr: ownr, code: code} %>

<% end %>