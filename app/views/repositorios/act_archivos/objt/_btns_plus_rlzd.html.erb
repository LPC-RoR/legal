<% unless !es_lista && act_archivo %>

	<% unless realizado %>
		<%= render layout: '0p/tltp_lnk', locals: {lnk: "/#{ownr.class.name.tableize}/#{ownr.id}/rlzd?mdl=act&cdg=#{code}&p=true", tltp: 'Realizado', data: {turbo_method: :post}} do %>
			<i class="bi bi-check-square"></i>
		<% end %>


		<%= render partial: '0p/tbl/lnk_new', locals: {source: 'act_archivos', gly: (mdl.act_lst?(code) ? 'plus-circle' : 'upload') ,ownr: ownr, tltp: "Agrega #{mdl.act_nombre[code].downcase}", prms: {act: code, mdl: mdl}} %>
	<% end %>
<% end %>