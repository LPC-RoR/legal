<% cntxt_clss 	= ClssCntrld.cntxt_clss(ownr.class.name.tableize) %>
<% cntxt_key	= cntxt_clss.cntxt_key(ownr) %>

<% cntxt_clss.archivos[cntxt_key].each do |arch| %>
	<% archivo = ownr.act_archivos.find_by(act_archivo: arch[0]) %>
	<div class="row gx-1 px-2 app_lnk">
		<div class="col-8">
			<i class="bi bi-file-earmark-pdf"></i>
			<%= arch[1] %>
		</div>
		<div class="col-4 text-end">
			<% if archivo %>
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/show_pdf", tltp: 'Ver PDF', target: '_blank'} do %>
					<i class="bi bi-download"></i>
				<% end %>
				<i class="bi bi-dot"></i>
				<%= render partial: '0p/tbl/link_eliminar', locals: {objeto: archivo} %>
			<% else %>
				<%= render partial: '0p/tbl/lnk_new', locals: {source: 'act_archivos', ownr: ownr, prms: [['act', arch[0]], ['mdl', cntxt_clss.to_s]]} %>
			<% end %>
		</div>
	</div>
<% end %>