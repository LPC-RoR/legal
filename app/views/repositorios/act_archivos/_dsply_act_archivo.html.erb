<% act_archivos 	= @objeto.act_archivos.exists?(act_archivo: rprt) %>
<% act_referencias 	= @objeto.act_referencias.exists?(code: rprt) %>
<% realizado 		= @objeto.check_realizados.exists?(cdg: rprt) %>

<div class="row gx-1 mx-1 mb-1 py-1 px-2 border rounded-2" style="font-size: .9rem;">
	<div class="col-8">
		<% unless act_archivos or act_referencias or realizado %>
			<i class="bi bi-cone-striped text-danger"></i> 
		<% end %>
		<%= ClssPrcdmnt.act_nombre[rprt] %>
	</div>
	<div class="col-4 text-end app_lnk">
		<%# Hay reportes que se pueden generar y enviar más de una vez, como infrmcn, hay que considerar esa posibilidad %>
		<% unless (act_archivos or act_referencias or realizado) and !ClssPdfRprt.mltpl_rprt(rprt) %>
			<%# Si hay más de uno como lo registro y se puede enviar uno y otro verificado!! %>
			<%#= render partial: 'repositorios/check_realizados/rlzbl', locals: {hsh: @acts_hsh, act_id: act_id, ownr: objeto, act: rprt} %>

			<%= render layout: '0p/tltp_lnk', locals: {lnk: "/#{objeto.class.name.tableize}/#{objeto.id}/rlzd?mdl=act&cdg=#{rprt}&p=true", tltp: 'Realizado', data: {turbo_method: :post}} do %>
				<i class="bi bi-check-square"></i>
			<% end %>


			<%# REPORTES ADMINISTRATIVOS : ownr = dstntr y ref = Denuncia %>
			<%= render layout: '0p/tltp_lnk', locals: {lnk:"/krn_denuncias/#{@objeto.id}/krn_pdf_rprt?rprt=#{rprt}&nid=#{objeto.id}", tltp: 'Generar, almacenar y enviar reporte', data: {turbo_method: :post, turbo_confirm: 'Confirmar envío de email'}} do %>
				<i class="bi bi-envelope-at"></i>
			<% end %>

		<% else %>

			<%## El borrado se ejecuta en cada línea %>

			<%#= render partial: 'repositorios/check_realizados/rlzd', locals: {hsh: @acts_hsh, act_id: act_id, ownr: objeto, act: rprt} if realizado %>
			<%#= render layout: '0p/tltp_lnk', locals: {lnk: "/#{objeto.class.name.tableize}/#{objeto.id}/rlzd?mdl=act&cdg=#{rprt}&p=trash", tltp: 'Eliminar marca de realizado', data: {turbo_method: :post}} do %>
				<!--i class="bi bi-trash"></i-->
			<%# end %>
		
		<% end %>
	</div>

<% if act_archivos or act_referencias %>

	<% lista = act_archivos ? @objeto.act_archivos.where(act_archivo: rprt) : @objeto.act_referencias.where(code: rprt) %>
	<% lista.each do |rgstr| %>
		<% archivo = act_archivos ? rgstr : rgstr.act_archivo %>
		<% if archivo %>
		<div class="row gx-1 px-4 text-primary objt_lnk">
			<div class="col-10">
				<i class="bi bi-arrow-return-right"></i>
				<i class="bi bi-file-pdf"></i>
				<%= dma_hm(archivo.created_at)%>
			</div>
			<div class="col-2 text-end">
				<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{archivo.id}/show_pdf", tltp: "Bajar #{ClssPrcdmnt.act_nombre[rprt].downcase}", target: '_blank'} do %>
					<i class="bi bi-download"></i>
				<% end %>
				<%# Sólo Dog puede eliminar un archivo enviado o generado %>
				<%= render partial: '0p/tbl/lnk_elmnr', locals: {objeto: archivo} if current_usuario.dog? %>
				<i class="bi bi-arrow-return-left"></i>
			</div>
		</div>
		<% end %>
	<% end %>
<% end %>

<% if realizado %>
	<% lista = @objeto.check_realizados.where(cdg: rprt) %>
	<% lista.each do |rgstr| %>
		<%= render partial: prtl(rgstr, nil, 'objeto'), locals: {objt: rgstr} %>
	<% end %>
<% end %>

</div>
