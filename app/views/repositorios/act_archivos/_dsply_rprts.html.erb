<%# LISTA de envío : %>
<!-- Información y notificaciones -->

<% actns = ClssPrcdmnt.acciones_que_aplican(ownr) %>

<%# each recorre las acciones que aplican a este participante %>
<% actns.each do |actn| %>

	<%# verifica que la accion no sea 'verificar_email', porque se resuelve por otro lado %>
	<% unless ClssPrcdmnt.list_excluded?(actn) %>

		<%= render partial: prtl('act_archivos', 'objt', 'objeto_rprt'), locals: {audit: ownr.dnnc.auditoria, mdl: ClssPrcdmnt, ownr: ownr, code: actn} %>
		
	<% end %>

<% end %>

<div><hr></div>

<%# PDFs GENERADOS DESDE SERVICIOS CON CONTEXTO %>
<% pdf_codes = ClssPdfInvstgcns.dsply_codes_for(ownr) %>

<% pdf_codes.each do |code| %>
	<%= render partial: prtl('act_archivos', 'objt', 'objeto_cntxt'), locals: {code: code, mdl: ClssPdfInvstgcns, ownr: ownr} %>
<% end %>