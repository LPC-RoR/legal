<% act_id = "#{ownr.class.name}_#{ownr.id}" %>

<% if hsh[act_id] %>

	<%# Se recorren los códigos de archivos %>
	<% hsh[act_id][:cdgs].each do |code| %>

		<% es_lista 		= mdl.act_lst?(code) %>

		<% act_archivos 	= es_lista ? ownr.act_archivos.where(act_archivo: code) : nil %>
		<% act_referencias 	= es_lista ? ownr.act_referencias.where(code: code) : nil %>
		<% chk_realizados 	= es_lista ? ownr.check_realizados.where(cdg: code) : nil %>

		<% act_archivo 		= es_lista ? nil : ownr.act_archivos.find_by(act_archivo: code) %>
		<% act_referencia	= es_lista ? nil : ownr.act_referencias.find_by(code: code) %>
		<% chk_realizado 	= es_lista ? nil : ownr.check_realizados.find_by(cdg: code) %>

		<% subido 			= act_archivos&.any? || act_referencias&.any? || act_archivo || act_referencia %>
		<% realizado 		= chk_realizados&.any? || chk_realizado %>

		<div class="row gx-1 text-<%=mdl.act_lst?(code) ? 'secondary' : 'primary'%>">

			<div class="col-10">

				<%# Archivo o Lista de archivos %>
				<% if es_lista %>
					<i class="bi bi-list-task"></i>
				<% else %>
					<i class="bi bi-file-earmark"></i>
					<% if subido %>
						<i class="bi bi-file-earmark-pdf"></i>
					<% elsif realizado %>
						<i class="bi bi-clipboard-check"></i>
					<% else %>
						<i class="bi bi-cone-striped text-<%= mdl.act_optnl?(code) ? 'primary' : 'danger' %>"></i>
					<% end %>
				<% end %>

				<%=mdl.act_nombre[code]%>
			</div>
			<div class="col-2 text-end app_lnk">
				<!-- Verificar uso de lnks, puede que el reporte no lo esté usando -->
				<% if dsply_lnks %>
					<!-- anonimización -->
					<!-- puse hsh[act_id][code] para resolver caída en producción, investigar -->

					<%# if mdl.annmzbl?(code) and hsh[act_id][code] %>
					<% if mdl.annmzbl?(code) and act_archivo %>
						<%# unless hsh[act_id][code].anonimizado_como.present? %>
						<% unless act_archivo.anonimizado_como.present? %>
							<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_archivo.id}/annmzr", tltp: "Anonimizar #{mdl.act_nombre[code]}", data: {turbo_method: :post}} do %>
								<i class="bi bi-eyeglasses"></i>
							<% end %>
						<% end %>
					<% end %>

					<!-- Botón plus de una lista | archivo -->
					<%# Se puede subir un archivo a menos que no sea lista y ya tenga uno %>
					<% unless !es_lista && act_archivo %>

						<% unless realizado %>
							<%= render layout: '0p/tltp_lnk', locals: {lnk: "/#{ownr.class.name.tableize}/#{@objeto.id}/rlzd?mdl=act&cdg=#{code}&p=true", tltp: 'Realizado', data: {turbo_method: :post}} do %>
								<i class="bi bi-check-square"></i>
							<% end %>


							<%= render partial: '0p/tbl/lnk_new', locals: {source: 'act_archivos', gly: (mdl.act_lst?(code) ? 'plus-circle' : 'upload') ,ownr: ownr, tltp: "Agrega #{mdl.act_nombre[code].downcase}", prms: {act: code, mdl: mdl}} %>
						<% end %>
					<% end %>

					<%# Manejo de un archivo ya subido. Realizado se maneja en listas, se puede realizar más de una vez %>
					<% if !es_lista && act_archivo %>
						<% if act_archivo %>
							<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{act_archivo.id}/download", tltp: "Bajar #{mdl.act_nombre[code].downcase}", target: '_blank'} do %>
								<i class="bi bi-download"></i>
							<% end %>
							<%= render partial: '0p/tbl/lnk_eliminar', locals: {objeto: act_archivo} %>
						<% end %>
					<% end %>
				<% end %>
			</div>
		</div>

		<%# LISTA de ActArchivo %>
		<% if es_lista %>
			<div class="ms-4 text-primary">
				<% act_archivos.each do |lst_fl| %>
					<div class="row gx-1">
						<div class="col-10">
							<i class="bi bi-arrow-return-right"></i>
							<% if lst_fl.rlzd? %>
								<i class="bi bi-clipboard-check"></i>
							<% else %>
								<i class="bi bi-file-earmark-pdf"></i>
							<% end %>
							<%=lst_fl.nombre%>
						</div>
						<div class="col-2 text-end app_lnk">
							<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{lst_fl.id}/download", tltp: "Bajar #{mdl.act_nombre[code].downcase}", target: '_blank'} do %>
								<i class="bi bi-download"></i>
							<% end %>

							<%# ActArchivo Notificable que NO tiene referencia %>
							<% act_sym = lst_fl.act_archivo.to_sym %>

							<% if ClssPdfRprt.rprt_ntfcbl?[act_sym] and lst_fl.act_referencias.none? %>
								<%# NUEVO Generar, adjuntar y enviar PDF %>
								<%= render layout: '0p/tltp_lnk', locals: {lnk:"/krn_denuncias/#{ownr.dnnc.id}/krn_pdf_rprt?rprt=#{ClssPdfRprt.rprt_ntfcbl?[act_sym]}&nid=#{lst_fl.id}", tltp: 'Generar, almacenar y enviar reporte', data: {turbo_method: :post, turbo_confirm: 'Confirmar envío de email'}} do %>
									<i class="bi bi-envelope-at"></i>
								<% end %>
							<% end %>

							<%= render partial: '0p/tbl/lnks_e', locals: {objeto: lst_fl} if dsply_lnks %>
						</div>
					</div>
				<% end %>
			</div>
		<% end %>

		<% if mdl.annmzbl?(code) and act_archivo and act_archivo.anonimizado_como.present? %>
			<% annmzd = act_archivo.anonimizado_como %>
			<div class="mx-3 text-primary">
				<div class="row gx-1">
					<div class="col-10">
						<i class="bi bi-arrow-return-right"></i>
						<i class="bi bi-sunglasses"></i>
						<%=dma_hm(annmzd.created_at)%>
					</div>
					<div class="col-2 text-end app_lnk">
						<%= render layout: '0p/tltp_lnk', locals: {lnk: "/act_archivos/#{annmzd.id}/download", tltp: "Bajar #{mdl.act_nombre[code].downcase}", target: '_blank'} do %>
							<i class="bi bi-download"></i>
						<% end %>
						<%= render partial: '0p/tbl/lnks_e', locals: {objeto: annmzd} if dsply_lnks %>
						<i class="bi bi-arrow-return-left"></i>
					</div>
				</div>
			</div>
		<% end %>

		<% if realizado %>
			<% lista = ownr.check_realizados.where(cdg: code) %>
			<% lista.each do |rgstr| %>
				<%= render partial: prtl(rgstr, nil, 'objeto'), locals: {objt: rgstr} %>
			<% end %>
		<% end %>

	<% end %>

<% end %>